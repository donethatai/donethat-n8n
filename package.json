{
  "name": "n8n-nodes-donethat",
  "version": "0.1.0",
  "description": "n8n community node for DoneThat reports, summaries, projects, and search.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "donethat",
    "productivity",
    "reports"
  ],
  "license": "MIT",
  "homepage": "https://github.com/donethatai/donethat-n8n",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donethatai/donethat-n8n.git"
  },
  "bugs": {
    "url": "https://github.com/donethatai/donethat-n8n/issues"
  },
  "author": "DoneThat",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts",
    "prepack": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/DoneThatApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/DoneThat/DoneThat.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "^2.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "n8n-core": "^2.16.1",
    "n8n-node-dev": "^1.121.16",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}
