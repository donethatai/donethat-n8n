{
  "name": "n8n-nodes-donethat",
  "version": "0.2.2",
  "description": "n8n community node for DoneThat reports, summaries, projects, and search.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "donethat",
    "productivity",
    "reports"
  ],
  "license": "MIT",
  "homepage": "https://github.com/donethatai/donethat-n8n",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donethatai/donethat-n8n.git"
  },
  "bugs": {
    "url": "https://github.com/donethatai/donethat-n8n/issues"
  },
  "author": "DoneThat",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json && node scripts/copy-assets.mjs && node scripts/verify-n8n-package.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "eslint .",
    "n8n:live": "node scripts/n8n-live.mjs start",
    "test": "npm run build && jest --testTimeout 30000",
    "test:coverage": "npm run build && jest --coverage --testTimeout 30000",
    "test:live": "node scripts/n8n-live.mjs test",
    "prepack": "npm run build",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "engines": {
    "node": ">=22.16"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/DoneThatApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/DoneThat/DoneThat.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "^2.16.0"
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.31.0",
    "@types/node": "^25.9.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "n8n-core": "^2.16.1",
    "n8n-node-dev": "^1.121.16",
    "n8n-workflow": "^2.16.0",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.10",
    "typescript": "^6.0.3"
  }
}
